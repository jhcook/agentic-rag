# Copy this file to `.env` and customize the values you need.
# Any variable you omit falls back to the defaults baked into the code.

# =========================
# Core Store & Debug Options
# =========================
RAG_DB=./cache/rag_store.jsonl                # Location of the persisted JSONL store
RAG_WORKDIR=                                  # Optional base path to resolve relative user inputs
RAG_DEBUG_MODE=false                          # If true, skips expensive embedding/index work for quick testing
MAX_MEMORY_MB=4096                            # Soft memory ceiling (http_server); auto-detects 75% of RAM when unset
REST_MAX_MEMORY_MB=                           # Override the REST server memory limit; falls back to MAX_MEMORY_MB

# ===============================
# Embeddings & Retrieval Settings
# ===============================
EMBED_MODEL_NAME=sentence-transformers/paraphrase-MiniLM-L3-v2   # Hugging Face model id or local path
EMBED_DIM_OVERRIDE=0                           # Force FAISS dimension (0 keeps the embedder's native size)
SEARCH_TOP_K=12                                # Default number of vector hits per query
SEARCH_MAX_CONTEXT_CHARS=8000                  # Max characters streamed into the LLM context window

# ==========================
# LLM & Prompt Configuration
# ==========================
LLM_MODEL_NAME=ollama/llama3.2:1b              # Completion model passed to LiteLLM (provider/name format)
ASYNC_LLM_MODEL_NAME=llama3.2:1b               # Model id used by AsyncClient-based chat helpers (no provider prefix)
LLM_TEMPERATURE=0.1                            # Low temperature keeps answers grounded/deterministic
LLM_TIMEOUT=180                                # Maximum seconds to wait for an Ollama/LiteLLM completion
SYSTEM_PROMPT="You are a knowledgeable librarian designed to search and summarise documents..."         # Search response prompt
GROUNDING_SYSTEM_PROMPT="You are a careful assistant. Write a concise professional summary..."         # Grounded answer prompt
OPENAI_API_BASE=                               # Set when using hosted OpenAI-compatible endpoints through LiteLLM

# ================================
# Ollama / Local LLM Service Setup
# ================================
START_OLLAMA=true                              # Let start.sh launch `ollama serve` automatically
SKIP_MODEL_PULL=false                          # If true, skip the automatic `ollama pull` step
OLLAMA_API_BASE=http://127.0.0.1:11434         # Base URL for Ollama HTTP API
OLLAMA_HOST=127.0.0.1                          # Interface for the embedded Ollama daemon (start.sh)
OLLAMA_PORT=11434                              # Port for the embedded Ollama daemon
OLLAMA_KEEP_ALIVE=-1                           # Keep models loaded (-1 indefinite, 24h, 5m, etc.)

# =============================
# MCP / REST / UI HTTP Endpoints
# =============================
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp
RAG_HOST=127.0.0.1                             # Host for the REST (FastAPI) shim
RAG_PORT=8001                                  # Port for the REST shim
RAG_PATH=/api                                  # Base path for REST routes
RAG_BASE=http://127.0.0.1:8001                 # Convenience base URL used by CLI clients
START_UI=true                                  # Launch the local web UI alongside the servers
UI_HOST=127.0.0.1
UI_PORT=4173

# ============================
# Startup / Environment Tweaks
# ============================
RECREATE_VENV=false                            # Force start.sh to recreate the virtual environment
VENV_NAME=.venv                                # Virtualenv folder name when start.sh bootstraps Python deps
PYTHON_CMD=python3                             # Python interpreter start.sh should prefer when recreating envs
SKIP_MODEL_PULL=false                          # (Repeated for clarity) avoid pulling Ollama models automatically

# ============================
# Torch / Platform Overrides
# ============================
TORCH_VERSION=                                 # Optional: pin a torch version (start.sh defaults to 2.2.2 on x86_64 CPU-only)
TORCH_INDEX_URL=                               # Optional: custom index for torch (defaults to PyTorch CPU wheels on x86_64)

# ===================================
# Cache / Dependency Download Folders
# ===================================
SENTENCE_TRANSFORMERS_HOME=                    # Override HF cache for sentence-transformers
TORCH_HOME=                                    # Location for torch model cache
HF_HOME=                                       # Hugging Face cache root (~/.cache/huggingface by default)
HUGGINGFACE_HUB_CACHE=                         # Explicit Hugging Face hub cache directory
